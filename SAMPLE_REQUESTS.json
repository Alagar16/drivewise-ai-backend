  "curlExamples": {
    "test1": "curl -X POST http://localhost:8080/api/cars/recommend -H 'Content-Type: application/json' -d '{\"budget\": 1500000, \"monthlyDistance\": \"high\", \"drivingPattern\": \"Mixed\", \"roadReality\": \"rough\", \"travelGroup\": \"family\", \"ownershipMindset\": \"safety\", \"fuelType\": \"Diesel\", \"vehicleType\": \"SUV\"}'",
    "test2": "curl -X POST http://localhost:8080/api/cars/recommend -H 'Content-Type: application/json' -d '{\"budget\": 600000, \"monthlyDistance\": \"low\", \"drivingPattern\": \"City\", \"roadReality\": \"smooth\", \"travelGroup\": \"solo\", \"ownershipMindset\": \"cost\", \"fuelType\": \"Petrol\", \"vehicleType\": \"HatchBack\"}'",
    "health": "curl http://localhost:8080/api/cars/health"
  },
  "postmanCollection": {
    "info": {
      "name": "Drivewise AI API",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
      {
        "name": "Get Recommendations",
        "request": {
          "method": "POST",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\"budget\": 1500000, \"monthlyDistance\": \"high\", \"drivingPattern\": \"Mixed\", \"roadReality\": \"rough\", \"travelGroup\": \"family\", \"ownershipMindset\": \"safety\", \"fuelType\": \"Diesel\", \"vehicleType\": \"SUV\"}"
          },
          "url": {
            "raw": "http://localhost:8080/api/cars/recommend",
            "protocol": "http",
            "host": ["localhost"],
            "port": "8080",
            "path": ["api", "cars", "recommend"]
          }
        }
      },
      {
        "name": "Health Check",
        "request": {
          "method": "GET",
          "url": {
            "raw": "http://localhost:8080/api/cars/health",
            "protocol": "http",
            "host": ["localhost"],
            "port": "8080",
            "path": ["api", "cars", "health"]
          }
        }
      }
    ]
  }
}

